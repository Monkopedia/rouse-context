<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      Required on Android 13+ (API 33) to post any notifications, including
      the foreground service notification, audit summaries, and authorization
      approval requests. Without this, NotificationManagerCompat.notify()
      silently no-ops on supported devices. Requested at runtime during
      onboarding (NotificationPreferencesScreen) and re-prompted on entry
      to the authorization approval flow if still denied. See issue #93.

      WAKE_LOCK and FOREGROUND_SERVICE / FOREGROUND_SERVICE_DATA_SYNC are
      contributed by :core:tunnel and :work module manifests via merger,
      so they are not redeclared here.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Health Connect: optional permission to read data recorded before
      the app was installed / granted access. Without this, Health Connect
      only returns records written after the user grants access.
      See issue #61.
    -->
    <uses-permission android:name="android.permission.health.READ_HEALTH_DATA_HISTORY" />

    <application
        android:name=".RouseApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.DayNight">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.RouseContext.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".receivers.AuthApprovalReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.rousecontext.ACTION_AUTH_APPROVE" />
                <action android:name="com.rousecontext.ACTION_AUTH_DENY" />
            </intent-filter>
        </receiver>

        <!-- Required for Health Connect permission request activity result contract -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!--
          Disable WorkManager's default on-demand initializer so our
          Configuration.Provider on RouseApplication (see RouseApplication.kt)
          is the sole source of truth. Without this, WorkManager eagerly initializes
          with its default WorkerFactory (which only invokes no-arg worker constructors),
          leaving lateinit fields on SecurityCheckWorker uninitialized. See issue #86.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
</manifest>
