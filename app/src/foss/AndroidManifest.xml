<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        FOSS-only: allow the tunnel foreground service to run as `specialUse`
        when the user opts into "Ignore daily time limit". specialUse has no
        Android 15 6h/24h cap (unlike dataSync). This permission and the
        specialUse type are NEVER declared in the google build: declaring
        specialUse triggers Google Play review, and Play steers persistent
        connections to FCM (which the google build already uses). Idle timeouts
        still govern teardown in both builds.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application>
        <!--
            UnifiedPush message receiver, present only in the `foss` flavor
            (issue #463). The Firebase-free counterpart of the google flavor's
            FcmReceiver. It receives wake/renew messages and endpoint
            registration callbacks from the user's chosen UnifiedPush
            distributor. No Firebase Cloud Messaging service in this flavor.
        -->
        <receiver
            android:name="com.rousecontext.app.push.UnifiedPushReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="org.unifiedpush.android.connector.MESSAGE" />
                <action android:name="org.unifiedpush.android.connector.UNREGISTERED" />
                <action android:name="org.unifiedpush.android.connector.NEW_ENDPOINT" />
                <action android:name="org.unifiedpush.android.connector.REGISTRATION_FAILED" />
            </intent-filter>
        </receiver>

        <!--
            Augment the :work-declared TunnelForegroundService so the foss build
            may enter the foreground as `specialUse` in addition to `dataSync`.
            The actual type used at runtime is chosen by FgsTypeSelector based on
            the "Ignore daily time limit" setting; dataSync stays the default.
            tools:replace overrides the :work manifest's dataSync-only value.
        -->
        <service
            android:name="com.rousecontext.work.TunnelForegroundService"
            android:foregroundServiceType="dataSync|specialUse"
            tools:replace="android:foregroundServiceType">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="On-demand MCP tunnel kept connected for the user's interactive AI sessions" />
        </service>
    </application>
</manifest>
